[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/onboarding/ModeTutorialModal.gd" id="1_modal"]
[ext_resource type="PackedScene" path="res://scenes/ui/foundation/ModalShell.tscn" id="2_shell"]
[ext_resource type="PackedScene" path="res://scenes/ui/foundation/PillButton.tscn" id="3_button"]

[node name="ModeTutorialModal" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_modal")

[node name="ModalShell" parent="." instance=ExtResource("2_shell")]
layout_mode = 1

[node name="Title" type="Label" parent="ModalShell/Panel/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.22, 0.15, 0.1, 1)
theme_override_font_sizes/font_size = 28
horizontal_alignment = 1

[node name="Demo" type="Label" parent="ModalShell/Panel/Content"]
custom_minimum_size = Vector2(0, 112)
layout_mode = 2
theme_override_colors/font_color = Color(0.85, 0.45, 0.2, 1)
theme_override_font_sizes/font_size = 44
horizontal_alignment = 1
vertical_alignment = 1

[node name="Description" type="Label" parent="ModalShell/Panel/Content"]
custom_minimum_size = Vector2(0, 88)
layout_mode = 2
theme_override_colors/font_color = Color(0.42, 0.3, 0.2, 1)
theme_override_font_sizes/font_size = 19
horizontal_alignment = 1
vertical_alignment = 1
autowrap_mode = 2

[node name="Actions" type="HBoxContainer" parent="ModalShell/Panel/Content"]
layout_mode = 2
theme_override_constants/separation = 12
alignment = 2

[node name="Skip" parent="ModalShell/Panel/Content/Actions" instance=ExtResource("3_button")]
custom_minimum_size = Vector2(100, 48)
layout_mode = 2
kind = 1
text = "Skip"
accessibility_label = "Skip tutorial"

[node name="Confirm" parent="ModalShell/Panel/Content/Actions" instance=ExtResource("3_button")]
custom_minimum_size = Vector2(120, 48)
layout_mode = 2
text = "Got it"
accessibility_label = "Finish tutorial"
